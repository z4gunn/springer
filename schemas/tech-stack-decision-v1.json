{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://springer.local/schemas/tech-stack-decision-v1.json",
  "title": "SPGR Tech Stack Decision v1",
  "allOf": [{ "$ref": "https://springer.local/schemas/_envelope-v1.json" }],
  "properties": {
    "artifact_type": { "const": "tech-stack-decision" },
    "content": { "$ref": "#/$defs/content" }
  },
  "$defs": {
    "content": {
      "type": "object",
      "required": ["layers"],
      "properties": {
        "layers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["layer", "selected", "rationale", "alternatives_considered"],
            "properties": {
              "layer": {
                "type": "string",
                "description": "language, framework, database, cache, queue, infrastructure, mobile, tooling, etc."
              },
              "selected": { "type": "string" },
              "version": { "type": "string" },
              "rationale": { "type": "string" },
              "alternatives_considered": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["option", "reason_rejected"],
                  "properties": {
                    "option": { "type": "string" },
                    "reason_rejected": { "type": "string" }
                  }
                }
              },
              "version_pinning": {
                "type": "string",
                "enum": ["pin-to-major", "pin-to-minor", "pin-to-exact"]
              },
              "upgrade_policy": { "type": "string" }
            }
          }
        },
        "adr_refs": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
