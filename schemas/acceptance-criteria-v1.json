{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://springer.local/schemas/acceptance-criteria-v1.json",
  "title": "SPGR Acceptance Criteria Set v1",
  "allOf": [{ "$ref": "https://springer.local/schemas/_envelope-v1.json" }],
  "properties": {
    "artifact_type": { "const": "acceptance-criteria" },
    "content": { "$ref": "#/$defs/content" }
  },
  "$defs": {
    "content": {
      "type": "object",
      "required": ["story_ref", "criteria", "scenarios_count"],
      "properties": {
        "story_ref": {
          "type": "string",
          "pattern": "^STORY-[0-9]{4}-[0-9]+$"
        },
        "criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "ac_id",
              "story_ref",
              "scenario_type",
              "given",
              "when",
              "then"
            ],
            "properties": {
              "ac_id": {
                "type": "string",
                "description": "AC-{story_id}-{seq}."
              },
              "story_ref": { "type": "string" },
              "scenario_type": {
                "type": "string",
                "enum": ["happy-path", "error-path", "boundary"]
              },
              "given": { "type": "string", "minLength": 1 },
              "when": { "type": "string", "minLength": 1 },
              "then": { "type": "string", "minLength": 1 },
              "nfr_constraint_ref": { "type": ["string", "null"] }
            }
          }
        },
        "coverage_summary": {
          "type": "object",
          "properties": {
            "happy_path": { "type": "boolean" },
            "error_path": { "type": "boolean" },
            "boundary": { "type": "boolean" }
          }
        },
        "scenarios_count": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
