{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://springer.local/schemas/data-dictionary-v1.json",
  "title": "SPGR Data Dictionary v1",
  "allOf": [{ "$ref": "https://springer.local/schemas/_envelope-v1.json" }],
  "properties": {
    "artifact_type": { "const": "data-dictionary" },
    "content": { "$ref": "#/$defs/content" }
  },
  "$defs": {
    "content": {
      "type": "object",
      "required": ["entities"],
      "properties": {
        "entities": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "fields"],
            "properties": {
              "name": { "type": "string" },
              "description": { "type": "string" },
              "fields": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["name", "type", "pii_classification"],
                  "properties": {
                    "name": { "type": "string" },
                    "type": { "type": "string" },
                    "constraints": { "type": "array", "items": { "type": "string" } },
                    "description": { "type": "string" },
                    "pii_classification": {
                      "type": "string",
                      "description": "Explicit on every field, including not-PII."
                    },
                    "fk_reference": { "type": ["string", "null"] }
                  }
                }
              }
            }
          }
        },
        "changelog": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["date", "change"],
            "properties": {
              "date": { "type": "string" },
              "change": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
