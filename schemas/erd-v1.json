{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://springer.local/schemas/erd-v1.json",
  "title": "SPGR Entity Relationship Diagram v1",
  "allOf": [{ "$ref": "https://springer.local/schemas/_envelope-v1.json" }],
  "properties": {
    "artifact_type": { "const": "erd" },
    "content": { "$ref": "#/$defs/content" }
  },
  "$defs": {
    "content": {
      "type": "object",
      "required": ["entities", "relationships", "mermaid"],
      "properties": {
        "entities": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "attributes"],
            "properties": {
              "name": { "type": "string" },
              "description": { "type": "string" },
              "attributes": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["name", "type", "pii_classification"],
                  "properties": {
                    "name": { "type": "string" },
                    "type": { "type": "string" },
                    "constraints": {
                      "type": "array",
                      "items": { "type": "string" }
                    },
                    "nullable": { "type": "boolean" },
                    "default": { "type": ["string", "number", "boolean", "null"] },
                    "pii_classification": {
                      "type": "string",
                      "description": "PII, PHI, financial, not-PII, etc."
                    }
                  }
                }
              }
            }
          }
        },
        "relationships": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "to", "cardinality"],
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" },
              "cardinality": {
                "type": "string",
                "enum": ["1:1", "1:N", "M:N"]
              },
              "optionality": { "type": "string" }
            }
          }
        },
        "mermaid": {
          "type": "string",
          "minLength": 1,
          "description": "Mermaid erDiagram source."
        }
      }
    }
  }
}
