{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://springer.local/schemas/pdca-cycle-v1.json",
  "title": "SPGR PDCA Cycle v1",
  "description": "Immutable record of one harness tick. The append-only sequence of these artifacts plus each artifact's decision_log is the run's source of truth. run-state is a derived projection over this log.",
  "allOf": [{ "$ref": "https://springer.local/schemas/_envelope-v1.json" }],
  "properties": {
    "artifact_type": { "const": "pdca-cycle" },
    "content": { "$ref": "#/$defs/content" }
  },
  "$defs": {
    "work_item": {
      "type": "object",
      "required": ["agent", "expected_outcome"],
      "properties": {
        "agent": {
          "type": "string",
          "minLength": 1,
          "description": "Slug of the domain agent to run for this unit of work."
        },
        "input_artifact_refs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "artifact_id of every input the agent reads."
        },
        "expected_outcome": {
          "type": "string",
          "minLength": 1,
          "description": "The artifact or transition this unit is expected to produce, used by Check to compare actual against expected."
        },
        "workstream": {
          "type": ["string", "null"],
          "description": "Workstream this unit belongs to, for WIP accounting and parallel scheduling."
        }
      }
    },
    "content": {
      "type": "object",
      "required": ["cycle_id", "cycle_number", "run_id", "phase", "plan", "do", "check", "act"],
      "properties": {
        "cycle_id": {
          "type": "string",
          "pattern": "^CYCLE-[0-9]{4,}$",
          "description": "CYCLE-{zero-padded monotonic sequence}."
        },
        "cycle_number": {
          "type": "integer",
          "minimum": 0,
          "description": "Monotonic tick counter within the run."
        },
        "run_id": { "type": "string", "minLength": 1 },
        "phase": {
          "type": "string",
          "minLength": 1,
          "description": "Active phase at this tick, for example requirements or development."
        },
        "plan": {
          "type": "object",
          "required": ["routed_batch", "rationale"],
          "description": "The routing decision returned by the orchestrator for this tick.",
          "properties": {
            "routed_batch": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/work_item" }
            },
            "rationale": { "type": "string", "minLength": 1 },
            "learnings_cited": {
              "type": "array",
              "items": { "type": "string" },
              "description": "retrospective learning_id values cited as advisory rationale. Advisory only, never dispositive."
            }
          }
        },
        "do": {
          "type": "object",
          "required": ["dispatched"],
          "description": "What the harness dispatched and what each agent produced.",
          "properties": {
            "dispatched": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["agent", "status"],
                "properties": {
                  "agent": { "type": "string", "minLength": 1 },
                  "produced_artifact_refs": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "status": {
                    "type": "string",
                    "enum": ["completed", "failed", "skipped"]
                  }
                }
              }
            }
          }
        },
        "check": {
          "type": "object",
          "required": ["verdict"],
          "description": "Validation, vertical-audit fan-out, and expected-versus-actual comparison.",
          "properties": {
            "verdict": {
              "type": "string",
              "enum": ["pass", "fail", "gate", "blocked"],
              "description": "pass advances, fail retries, gate pauses for a human, blocked routes an escalation."
            },
            "validations": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["artifact_ref", "result"],
                "properties": {
                  "artifact_ref": { "type": "string", "minLength": 1 },
                  "result": { "type": "string", "enum": ["valid", "invalid"] },
                  "issues": { "type": "array", "items": { "type": "string" } }
                }
              }
            },
            "audits": {
              "type": "array",
              "description": "Always-active vertical audits run in parallel against the produced artifacts.",
              "items": {
                "type": "object",
                "required": ["audit", "verdict"],
                "properties": {
                  "audit": { "type": "string", "minLength": 1 },
                  "target_ref": { "type": ["string", "null"] },
                  "verdict": { "type": "string", "enum": ["PASS", "GATE"] },
                  "findings_summary": { "type": ["string", "null"] }
                }
              }
            },
            "expectation_match": {
              "type": ["boolean", "null"],
              "description": "Whether the actual outcome matched the expected_outcome from Plan."
            }
          }
        },
        "act": {
          "type": "object",
          "required": ["transition"],
          "description": "The state transition performed, and the batch to run on resume when paused.",
          "properties": {
            "transition": {
              "type": "string",
              "enum": ["advance", "retry", "escalate", "pause", "complete"]
            },
            "state_changes": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Human-readable WIP-board transitions, for example STORY-1 development to review."
            },
            "versioned_refs": {
              "type": "array",
              "items": { "type": "string" },
              "description": "artifact_id of every artifact versioned or archived this tick."
            },
            "escalation_ref": { "type": ["string", "null"] },
            "checkpoint_ref": {
              "type": ["string", "null"],
              "description": "hil-checkpoint artifact written when transition is pause."
            },
            "pending_batch": {
              "anyOf": [
                { "type": "array", "items": { "$ref": "#/$defs/work_item" } },
                { "type": "null" }
              ],
              "description": "The work to dispatch on resume. Set when transition is pause so resume is deterministic rather than reconstructed from prose."
            }
          }
        },
        "next_phase": { "type": ["string", "null"] }
      }
    }
  }
}
