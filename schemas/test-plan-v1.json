{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://springer.local/schemas/test-plan-v1.json",
  "title": "SPGR Test Plan v1",
  "allOf": [{ "$ref": "https://springer.local/schemas/_envelope-v1.json" }],
  "properties": {
    "artifact_type": { "const": "test-plan" },
    "content": { "$ref": "#/$defs/content" }
  },
  "$defs": {
    "content": {
      "type": "object",
      "required": ["scope", "test_type_matrix", "coverage_targets", "entry_criteria", "exit_criteria"],
      "properties": {
        "scope": { "type": "string", "minLength": 1 },
        "story_refs": { "type": "array", "items": { "type": "string" } },
        "test_type_matrix": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["test_type", "tooling", "owner_agent", "run_frequency", "environment"],
            "properties": {
              "test_type": {
                "type": "string",
                "enum": ["unit", "integration", "e2e", "performance", "security", "accessibility", "contract", "smoke"]
              },
              "tooling": { "type": "string" },
              "owner_agent": { "type": "string" },
              "run_frequency": { "type": "string" },
              "environment": { "type": "string" }
            }
          }
        },
        "coverage_targets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["layer", "target"],
            "properties": {
              "layer": { "type": "string" },
              "target": { "type": "string" }
            }
          }
        },
        "risk_weighted_coverage": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["risk_area", "additional_test_types"],
            "properties": {
              "risk_area": { "type": "string" },
              "additional_test_types": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "entry_criteria": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "exit_criteria": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "environment_requirements": { "type": "array", "items": { "type": "string" } },
        "test_data_strategy": { "type": "string" }
      }
    }
  }
}
